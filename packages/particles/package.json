{
  "name": "@voxelize/particles",
  "version": "0.1.0",
  "description": "Bespoke typed particle system for Voxelize. WebGPU/TSL-safe, no ShaderMaterial.",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    "require": "./dist/index.js",
    "import": "./dist/index.mjs",
    "types": "./dist/index.d.ts"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "watch": "cross-env NODE_ENV=development pnpm build --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts-resolve",
    "prepublishOnly": "pnpm run build"
  },
  "license": "MIT",
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "three": "^0.183.0",
    "tsup": "^5.12.9",
    "typescript": "^5"
  }
}
